# Firebase web SDK config for the WeatherBot SPA.
# These values are NOT secrets in the cryptographic sense — they identify
# the Firebase project to the browser. Real authorization is enforced by
# Firebase Auth + Firestore Security Rules.
#
# Copy this file to .env.local (gitignored) and fill in the real values from:
#   firebase apps:sdkconfig WEB --project=weatherbot-app

VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=weatherbot-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=weatherbot-app
VITE_FIREBASE_STORAGE_BUCKET=weatherbot-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
