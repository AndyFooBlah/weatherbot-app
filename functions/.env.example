# Copy to functions/.env (gitignored) and fill in for your environment.
# Firebase Functions params (defineString) read this file at deploy time.

# Cloud Run URL of the deployed weatherbot-toolbox MCP service.
# Find yours with:
#   gcloud run services describe weatherbot-toolbox --region=us-central1 \
#     --format='value(status.url)'
TOOLBOX_URL=https://your-toolbox-service.run.app
